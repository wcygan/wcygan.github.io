# act configuration for wcygan.github.io
# This file configures nektos/act for better GitHub Actions simulation

# Use ubuntu-latest compatible image for GitHub Actions
-P ubuntu-latest=catthehacker/ubuntu:act-latest

# Set reasonable container options
--container-options "--memory=2g --cpus=2"

# Use artifact server for better artifact handling
--artifact-server-path /tmp/artifacts

# Enable verbose logging for better debugging
--verbose

# Platform mappings for consistent behavior
-P ubuntu-22.04=catthehacker/ubuntu:act-22.04
-P ubuntu-20.04=catthehacker/ubuntu:act-20.04 