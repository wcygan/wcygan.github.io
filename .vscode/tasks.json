{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Test GitHub Actions (All)",
			"type": "shell",
			"command": "deno",
			"args": ["run", "--allow-all", "scripts/test-github-actions.ts"],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "Test GitHub Actions (CI Only)",
			"type": "shell",
			"command": "deno",
			"args": ["run", "--allow-all", "scripts/test-github-actions.ts", "--workflow", "ci"],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "Test GitHub Actions (Verbose)",
			"type": "shell",
			"command": "deno",
			"args": ["run", "--allow-all", "scripts/test-github-actions.ts", "--verbose"],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "Check GitHub Actions Prerequisites",
			"type": "shell",
			"command": "deno",
			"args": ["run", "--allow-all", "scripts/test-github-actions.ts", "--dry-run"],
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": []
		}
	]
}
